# Plantilla del .env para el backend.
# Copia este archivo como `.env` y rellena los valores.
JWT_SECRET=
PORT=3000
FRONTEND_URL=http://localhost:4200

# ── SMTP para alertas por email ───────────────────────────────────────────────
# Si no se configuran, el sistema funciona normal pero no enviará emails.
# Ejemplo con Gmail: SMTP_HOST=smtp.gmail.com, PORT=587, usar App Password.
SMTP_HOST=smtp.mail.adro.com.co
SMTP_PORT=587
SMTP_USER=notificaciones@adro.com.co
SMTP_PASS=Notificaciones15963*%
